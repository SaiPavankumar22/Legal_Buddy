PORT=4000
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=gemma4:e2b

# Optional: set only if you have a local Ollama embedding model whose
# output dimension matches the bundled FAISS index.
OLLAMA_EMBED_MODEL=nomic-embed-text

# Or use a local Hugging Face embedding model installed through
# sentence-transformers for both index building and query-time retrieval.
EMBEDDING_PROVIDER=ollama
HF_EMBED_MODEL=

MAX_PDF_PAGES=8
MAX_TEXT_CHARS=16000
LEGAL_CONTEXT_TOP_K=4
CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:8080,http://localhost:8080
